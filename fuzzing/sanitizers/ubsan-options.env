# UBSan runtime options for Ledger fuzz campaigns.
# Sourced by fuzzing/sanitizers/load-options.sh → exported as UBSAN_OPTIONS.
# One key=value per line; comments and blank lines are stripped by the loader.

# Keep the campaign alive on UB — we want the report, not an abort.
halt_on_error=0

# Full diagnostic including where the UB fired.
print_stacktrace=1

# Always include the check name (signed-integer-overflow, function, …).
report_error_type=1
