# ASan runtime options for Ledger fuzz campaigns.
# Sourced by fuzzing/sanitizers/load-options.sh → exported as ASAN_OPTIONS.
#
# Real memory bugs must stop the worker — libFuzzer records the crash and
# spawns a fresh one.

abort_on_error=1
halt_on_error=1

# Stack use-after-return detection (costs ~2x stack; fine for fuzz).
detect_stack_use_after_return=1

# Catches pointer arithmetic across different allocations.
detect_invalid_pointer_pairs=2

# Stronger string-API checks (strlen, strnlen, …).
strict_string_checks=1

# Catch new/malloc vs delete/free mismatch (the mock layer uses C++ helpers).
alloc_dealloc_mismatch=1

# Global-init ordering.
check_initialization_order=1
strict_init_order=1

# Return freed memory to the OS sooner so unmap checks bite faster.
allocator_release_to_os_interval_ms=500
